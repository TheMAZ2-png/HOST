@page
@model HOST.Pages.ManagerAccounts.IndexModel

@{
    ViewData["Title"] = "Manager Accounts";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="d-flex gap-3 mb-4 fade-in-3">
        <a asp-page="Create" class="btn-primary btn-hero">
            Create New Manager
        </a>
    </div>

    <div class="card card-pink shadow fade-in-4">
        <div class="card-body p-4">

            <table class="table-pink fade-in-4">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Created At</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <!--Comment-->
                <tbody>
                    @foreach (var account in Model.ManagerAccounts)
                    {
                        <tr>
                            <td>@account.Email</td>
                            <td>@account.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                            <td class="text-end">
                                <div class="action-buttons">
                                    <a asp-page="Details"
                                           asp-route-id="@account.ManagerId"
                                           class="btn-secondary btn-sm">
                                        Details
                                    </a>

                                    <a asp-page="Edit"
                                           asp-route-id="@account.ManagerId"
                                           class="btn-primary btn-sm">
                                        Edit
                                    </a>

                                    <a asp-page="Delete"
                                           asp-route-id="@account.ManagerId"
                                           class="btn-danger-pink btn-sm">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
