@page
@model HOST.Pages.ManagerAccounts.IndexModel

@{
    ViewData["Title"] = "Manager Accounts";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="mb-3 fade-in-3">
        <a class="btn-primary btn-hero" asp-page="Create">New Manager Account</a>
    </div>

    <div class="card card-pink shadow fade-in-4">
        <div class="card-body p-4">

            <table class="table table-pink">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Created At</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ManagerAccounts)
                    {
                        <tr>
                            <td>@item.Email</td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                <div class="action-buttons">
                                    <a class="btn-secondary btn-sm" asp-page="Details" asp-route-id="@item.ManagerId">Details</a>
                                    <a class="btn-primary btn-sm" asp-page="Edit" asp-route-id="@item.ManagerId">Edit</a>
                                    <a class="btn-danger-pink btn-sm" asp-page="Delete" asp-route-id="@item.ManagerId">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
