@page "{id:int}"
@model HOST.Pages.ManagerAccounts.DeleteModel

@{
    ViewData["Title"] = "Delete Manager Account";
}

<h1>@ViewData["Title"]</h1>

<h3>Are you sure you want to delete this manager account?</h3>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.Email</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="ManagerAccount.ManagerId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
