@page "{id:int}"
@model HOST.Pages.ManagerAccounts.DeleteModel

@{
    ViewData["Title"] = "Delete Manager Account";
}

<h1>@ViewData["Title"]</h1>

<h4>Are you sure you want to delete this manager account?</h4>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.Email</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="ManagerAccount.ManagerId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>
