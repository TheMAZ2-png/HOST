@page "{id:int}"
@model HOST.Pages.ManagerAccounts.DetailsModel

@{
    ViewData["Title"] = "Manager Account Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.Email</dd>

    <dt class="col-sm-3">Password Hash</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.PasswordHash</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.ManagerAccount.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.ManagerAccount.ManagerId">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
