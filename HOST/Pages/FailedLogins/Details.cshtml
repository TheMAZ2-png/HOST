@page "{id:int}"
@model HOST.Pages.FailedLogins.DetailsModel

@{
    ViewData["Title"] = "Failed Login Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Username</dt>
    <dd class="col-sm-9">@Model.FailedLogin.Username</dd>

    <dt class="col-sm-3">Timestamp</dt>
    <dd class="col-sm-9">@Model.FailedLogin.Timestamp.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">IP Address</dt>
    <dd class="col-sm-9">@Model.FailedLogin.IpAddress</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.FailedLogin.Id">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
