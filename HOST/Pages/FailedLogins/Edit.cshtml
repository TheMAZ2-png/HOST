@page "{id:int}"
@model HOST.Pages.FailedLogins.EditModel

@{
    ViewData["Title"] = "Edit Failed Login";
}

<h1>@ViewData["Title"]</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="FailedLogin.Id" />

    <div class="mb-3">
        <label asp-for="FailedLogin.Username" class="form-label"></label>
        <input asp-for="FailedLogin.Username" class="form-control" />
        <span asp-validation-for="FailedLogin.Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FailedLogin.Timestamp" class="form-label"></label>
        <input asp-for="FailedLogin.Timestamp" class="form-control" type="datetime-local" />
        <span asp-validation-for="FailedLogin.Timestamp" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FailedLogin.IpAddress" class="form-label"></label>
        <input asp-for="FailedLogin.IpAddress" class="form-control" />
        <span asp-validation-for="FailedLogin.IpAddress" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
