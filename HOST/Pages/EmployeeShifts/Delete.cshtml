@page "{id:int}"
@model HOST.Pages.EmployeeShifts.DeleteModel

@{
    ViewData["Title"] = "Delete Shift";
}

<h1>@ViewData["Title"]</h1>

<h4>Are you sure you want to delete this shift?</h4>

<dl class="row">
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.EmployeeShift.EmployeeId</dd>

    <dt class="col-sm-3">Clock In</dt>
    <dd class="col-sm-9">@Model.EmployeeShift.ClockInAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="EmployeeShift.ShiftId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>
