@page "{id:int}"
@model HOST.Pages.EmployeeShifts.EditModel

@{
    ViewData["Title"] = "Edit Shift";
}

<h1>@ViewData["Title"]</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="EmployeeShift.ShiftId" />

    <div class="mb-3">
        <label asp-for="EmployeeShift.EmployeeId" class="form-label"></label>
        <input asp-for="EmployeeShift.EmployeeId" class="form-control" type="number" />
        <span asp-validation-for="EmployeeShift.EmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeShift.ClockInAt" class="form-label"></label>
        <input asp-for="EmployeeShift.ClockInAt" class="form-control" type="datetime-local" />
        <span asp-validation-for="EmployeeShift.ClockInAt" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeShift.ClockOutAt" class="form-label"></label>
        <input asp-for="EmployeeShift.ClockOutAt" class="form-control" type="datetime-local" />
        <span asp-validation-for="EmployeeShift.ClockOutAt" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeShift.ClockInByEmployeeId" class="form-label"></label>
        <input asp-for="EmployeeShift.ClockInByEmployeeId" class="form-control" type="number" />
        <span asp-validation-for="EmployeeShift.ClockInByEmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeShift.ClockOutByEmployeeId" class="form-label"></label>
        <input asp-for="EmployeeShift.ClockOutByEmployeeId" class="form-control" type="number" />
        <span asp-validation-for="EmployeeShift.ClockOutByEmployeeId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
