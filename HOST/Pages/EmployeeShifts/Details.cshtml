@page "{id:int}"
@model HOST.Pages.EmployeeShifts.DetailsModel

@{
    ViewData["Title"] = "Shift Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.EmployeeShift.EmployeeId</dd>

    <dt class="col-sm-3">Clock In</dt>
    <dd class="col-sm-9">@Model.EmployeeShift.ClockInAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Clock Out</dt>
    <dd class="col-sm-9">@(Model.EmployeeShift.ClockOutAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

    <dt class="col-sm-3">Clocked In By</dt>
    <dd class="col-sm-9">@(Model.EmployeeShift.ClockInByEmployeeId?.ToString() ?? "-")</dd>

    <dt class="col-sm-3">Clocked Out By</dt>
    <dd class="col-sm-9">@(Model.EmployeeShift.ClockOutByEmployeeId?.ToString() ?? "-")</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.EmployeeShift.ShiftId">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
