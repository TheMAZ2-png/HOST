@page "{id:int}"
@model HOST.Pages.RestaurantTables.DeleteModel

@{
    ViewData["Title"] = "Delete Table";
}

<h1 class="mb-4">Delete Table @Model.RestaurantTable.TableNumber</h1>

<div class="card card-pink shadow p-4">

    @if (Model.RestaurantTable.CurrentPartyId != null)
    {
        <div class="alert alert-danger">
            <strong>This table cannot be deleted.</strong><br />
            A party is currently seated at this table.
        </div>

        <a asp-page="Index" class="btn btn-secondary mt-3">Back</a>
    }
    else
    {
        <h4>Are you sure you want to delete this table?</h4>

        <p class="mt-3">
            <strong>Section:</strong> @Model.RestaurantTable.Section<br />
            <strong>Seats:</strong> @Model.RestaurantTable.SeatCapacity<br />
            <strong>Status:</strong> @Model.RestaurantTable.Status
        </p>

        <form method="post" class="mt-4">

            <!-- REQUIRED: send TableId back to POST handler -->
            <input type="hidden" asp-for="RestaurantTable.TableId" />

            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-page="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    }

</div>
