@page
@model HOST.Pages.RestaurantTables.IndexModel

@{
    ViewData["Title"] = "Restaurant Tables";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a class="btn btn-primary" asp-page="Create">New Table</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Table Number</th>
            <th>Seat Capacity</th>
            <th>Section</th>
            <th>Status</th>
            <th>Current Party</th>
            <th>Active</th>
            <th class="text-end"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.RestaurantTables)
        {
            <tr>
                <td>@item.TableNumber</td>
                <td>@item.SeatCapacity</td>
                <td>@item.Section</td>
                <td>@item.Status</td>

                <td>
                    @if (item.CurrentParty != null)
                    {
                        <span>@item.CurrentParty.PartyName (@item.CurrentParty.PartySize)</span>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </td>

                <td>@(item.IsActive ? "Yes" : "No")</td>

                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@item.TableId">Details</a>
                    <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@item.TableId">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@item.TableId">Delete</a>

                    @* ⭐ NEW: Clear button only when a party is seated *@
                    @if (item.CurrentPartyId != null)
                    {
                        <a class="btn btn-sm btn-warning"
                               asp-page="Clear"
                               asp-route-id="@item.TableId">
                            Clear
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
