@page
@model HOST.Pages.RestaurantTables.IndexModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Restaurant Tables";

    bool isManager = User.IsInRole("Manager");
    bool isHost = User.IsInRole("Host");
    bool isServer = User.IsInRole("Server");
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    @if (isManager || isHost)
    {
        <div class="d-flex gap-3 mb-4 fade-in-3">

            <a class="btn-primary btn-hero" asp-page="Create">
                New Table
            </a>

            <form method="post" asp-page-handler="ClearAll">
                <button type="submit"
                        class="btn-secondary btn-hero"
                        onclick="return confirm('Clear ALL tables? This will complete all parties and reset all tables.');">
                    Clear All Tables
                </button>
            </form>

            @if (isManager)
            {
                <form method="post" asp-page-handler="DeleteAll">
                    <button type="submit"
                            class="btn-danger-pink btn-hero"
                            onclick="return confirm('DELETE ALL TABLES? This will permanently remove every table.');">
                        Delete All Tables
                    </button>
                </form>
            }
        </div>
    }

    <div class="card card-pink shadow fade-in-4">
        <div class="card-body p-4">

            <table class="table-pink fade-in-4">
                <thead>
                    <tr>
                        <th>Table Number</th>
                        <th>Seat Capacity</th>
                        <th>Section</th>
                        <th>Status</th>
                        <th>Current Party</th>
                        <th>Active</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.RestaurantTables)
                    {
                        <tr>
                            <td>@item.TableNumber</td>
                            <td>@item.SeatCapacity</td>
                            <td>@item.Section</td>
                            <td>@item.Status</td>

                            <td>
                                @if (item.CurrentParty != null)
                                {
                                    <span>@item.CurrentParty.PartyName (@item.CurrentParty.PartySize)</span>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>

                            <td>@(item.IsActive ? "Yes" : "No")</td>

                            <td class="text-end">
                                <div class="action-buttons">

                                    <a class="btn-secondary btn-sm"
                                           asp-page="Details"
                                           asp-route-id="@item.TableId">
                                        Details
                                    </a>

                                    @if (isManager || isHost)
                                    {
                                        <a class="btn-primary btn-sm"
                                               asp-page="Edit"
                                               asp-route-id="@item.TableId">
                                            Edit
                                        </a>

                                        <a class="btn-danger-pink btn-sm"
                                               asp-page="Delete"
                                               asp-route-id="@item.TableId">
                                            Delete
                                        </a>
                                    }

                                    @if (item.CurrentPartyId != null)
                                    {
                                        <a class="btn-danger-pink btn-sm"
                                               asp-page="Clear"
                                               asp-route-id="@item.TableId">
                                            Clear
                                        </a>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
