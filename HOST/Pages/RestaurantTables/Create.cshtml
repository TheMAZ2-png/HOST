@page
@model HOST.Pages.RestaurantTables.CreateModel

@{
    ViewData["Title"] = "Create Table";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            <form method="post" class="fade-in-4">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- TABLE NUMBER -->
                <div class="mb-3">
                    <label asp-for="RestaurantTable.TableNumber" class="form-label text-pink-dark"></label>
                    <input asp-for="RestaurantTable.TableNumber"
                           class="form-control input-pink"
                           type="number"
                           min="0"
                           required />
                    <span asp-validation-for="RestaurantTable.TableNumber" class="text-danger"></span>
                </div>

                <!-- SEAT CAPACITY -->
                <div class="mb-3">
                    <label asp-for="RestaurantTable.SeatCapacity" class="form-label text-pink-dark"></label>
                    <input asp-for="RestaurantTable.SeatCapacity"
                           class="form-control input-pink"
                           type="number"
                           min="0"
                           max="12"
                           required />
                    <span asp-validation-for="RestaurantTable.SeatCapacity" class="text-danger"></span>
                </div>

                <!-- SECTION -->
                <div class="mb-3">
                    <label asp-for="RestaurantTable.Section" class="form-label text-pink-dark"></label>
                    <input asp-for="RestaurantTable.Section" class="form-control input-pink" required />
                    <span asp-validation-for="RestaurantTable.Section" class="text-danger"></span>
                </div>

                <!-- ACTIVE (hidden but always true) -->
                <input type="hidden" asp-for="RestaurantTable.IsActive" value="true" />

                <!-- BUTTONS -->
                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn-primary btn-hero">Save</button>
                    <a class="btn-secondary" asp-page="Index">Cancel</a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
