@page "{id:int}"
@model HOST.Pages.Employees.DetailsModel

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            <dl class="row fade-in-4 text-pink-dark">

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Employee.Name</dd>

                <dt class="col-sm-3">Display Name</dt>
                <dd class="col-sm-9">@Model.Employee.DisplayName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Employee.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Employee.Phone</dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">@Model.Employee.Role</dd>

                <dt class="col-sm-3">Identity User ID</dt>
                <dd class="col-sm-9">@Model.Employee.IdentityUserId</dd>

                <dt class="col-sm-3">Created At</dt>
                <dd class="col-sm-9">@Model.Employee.CreatedAt.ToString("g")</dd>

                <dt class="col-sm-3">Updated At</dt>
                <dd class="col-sm-9">
                    @(Model.Employee.UpdatedAt.HasValue
                        ? Model.Employee.UpdatedAt.Value.ToString("g")
                        : "—")
                </dd>

            </dl>

            <div class="mt-4 d-flex gap-3">
                <a class="btn-secondary" asp-page="Index">Back</a>
                <a class="btn-primary" asp-page="Edit" asp-route-id="@Model.Employee.EmployeeId">Edit</a>
            </div>

        </div>
    </div>

</div>
