@page "{id:int}"
@model HOST.Pages.Seatings.DetailsModel

@{
    ViewData["Title"] = "Seating Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Assigned Server</dt>
    <dd class="col-sm-9">@Model.Seating.AssignedServerId</dd>

    <dt class="col-sm-3">Seated By</dt>
    <dd class="col-sm-9">@Model.Seating.SeatedByEmployeeId</dd>

    <dt class="col-sm-3">Table</dt>
    <dd class="col-sm-9">@Model.Seating.RestaurantTableId</dd>

    <dt class="col-sm-3">Party</dt>
    <dd class="col-sm-9">@Model.Seating.PartyId</dd>

    <dt class="col-sm-3">Seated At</dt>
    <dd class="col-sm-9">@Model.Seating.SeatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Cleared At</dt>
    <dd class="col-sm-9">@(Model.Seating.ClearedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.Seating.SeatingId">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
