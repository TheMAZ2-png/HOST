@page "{id:int}"
@model HOST.Pages.Roles.DetailsModel

@{
    ViewData["Title"] = "Role Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Role Name</dt>
    <dd class="col-sm-9">@Model.Role.RoleName</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.Role.RoleId">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
