@page "{id:int}"
@model HOST.Pages.Parties.EditModel

@{
    ViewData["Title"] = "Edit Party";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">Edit Party</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- REQUIRED HIDDEN ID FIELD -->
                <input type="hidden" asp-for="Party.PartyId" />

                <div class="mb-3">
                    <label class="form-label text-pink-dark">Party Name</label>
                    <input asp-for="Party.PartyName" class="form-control input-pink" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-pink-dark">Phone Number</label>
                    <input asp-for="Party.PhoneNumber" class="form-control input-pink" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-pink-dark">Party Size</label>
                    <input asp-for="Party.PartySize" class="form-control input-pink" type="number" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-pink-dark">Notes</label>
                    <textarea asp-for="Party.Notes" class="form-control input-pink"></textarea>
                </div>

                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn-primary btn-hero">Save</button>
                    <a class="btn-secondary" asp-page="Index">Cancel</a>
                </div>

            </form>

           

        </div>
    </div>

</div>
