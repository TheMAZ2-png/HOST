@page "{id:int}"
@using System.Security.Claims
@model HOST.Pages.Parties.EditModel

@{
    ViewData["Title"] = "Edit Party";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">Edit Party</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            @* BLOCK EDITING IF PARTY IS NOT WAITING *@
            @if (Model.Party.Status != "Waiting" && !User.IsInRole("Manager"))
            {
                <div class="alert alert-danger fade-in-4">
                    <strong>This party cannot be edited.</strong><br />
                    Only parties that are still <strong>Waiting</strong> may be edited by guests.
                </div>

                <a asp-page="Index" class="btn-secondary mt-3">Back</a>
            }
            else
            {
                <!-- MAIN EDIT FORM -->
                <form method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Required hidden fields -->
                    <input type="hidden" asp-for="Party.PartyId" />
                    <input type="hidden" asp-for="Party.OwnerId" />

                    <div class="mb-3">
                        <label class="form-label text-pink-dark">Party Name</label>
                        <input asp-for="Party.PartyName" class="form-control input-pink" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-pink-dark">Phone Number</label>
                        <input asp-for="Party.PhoneNumber" class="form-control input-pink" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-pink-dark">Party Size</label>

                        <select asp-for="Party.PartySize"
                                class="form-control input-pink"
                                required>
                            <option value="">Select party size...</option>

                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(Model.Party.PartySize == i)">
                                    @i
                                </option>
                            }
                        </select>
                    </div>


                    <div class="mb-3">
                        <label class="form-label text-pink-dark">Notes</label>
                        <textarea asp-for="Party.Notes" class="form-control input-pink"></textarea>
                    </div>

                    <div class="mt-4 d-flex gap-3">
                        <button type="submit" class="btn-primary btn-hero">Save</button>
                        <a class="btn-secondary" asp-page="Index">Cancel</a>
                    </div>

                </form>

                <!-- DELETE FORM -->
                @if (User.IsInRole("Manager") ||
                                     (Model.Party.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier)
                                      && Model.Party.Status == "Waiting"))
                {
                    <form method="post"
                          asp-page-handler="Delete"
                          asp-route-id="@Model.Party.PartyId"
                          class="mt-3"
                          onsubmit="return confirm('Are you sure you want to delete your party?');">

                        <button type="submit" class="btn-danger-pink btn-hero">
                            Delete Party
                        </button>
                    </form>
                }
            }

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
