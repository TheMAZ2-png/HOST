@page
@model HOST.Pages.Parties.CreateModel

@{
    ViewData["Title"] = "Create Party";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            <form method="post" class="fade-in-4">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- PARTY NAME -->
                <div class="mb-3">
                    <label asp-for="PartyInput.PartyName" class="form-label text-pink-dark"></label>
                    <input asp-for="PartyInput.PartyName" class="form-control input-pink" />
                    <span asp-validation-for="PartyInput.PartyName" class="text-danger"></span>
                </div>

                <!-- PHONE NUMBER -->
                <div class="mb-3">
                    <label asp-for="PartyInput.PhoneNumber" class="form-label text-pink-dark"></label>
                    <input asp-for="PartyInput.PhoneNumber" class="form-control input-pink" />
                    <span asp-validation-for="PartyInput.PhoneNumber" class="text-danger"></span>
                </div>

                <!-- PARTY SIZE -->
                <div class="mb-3">
                    <label asp-for="PartyInput.PartySize" class="form-label text-pink-dark"></label>
                    <input asp-for="PartyInput.PartySize" class="form-control input-pink" type="number" min="1" max="12" />
                    <span asp-validation-for="PartyInput.PartySize" class="text-danger"></span>
                </div>

                <!-- NOTES -->
                <div class="mb-3">
                    <label asp-for="PartyInput.Notes" class="form-label text-pink-dark"></label>
                    <textarea asp-for="PartyInput.Notes" class="form-control textarea-pink" rows="8"></textarea>
                    <span asp-validation-for="PartyInput.Notes" class="text-danger"></span>
                </div>

                <!-- BUTTONS -->
                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn-primary btn-hero">Create</button>
                    <a class="btn-secondary" asp-page="Index">Cancel</a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
