@page "{id:int}"
@using System.Security.Claims
@model HOST.Pages.Parties.DetailsModel

@{
    ViewData["Title"] = "Party Details";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="card card-pink shadow fade-in-3">
        <div class="card-body p-4">

            <dl class="row text-pink-dark">

                <dt class="col-sm-3">Party Name</dt>
                <dd class="col-sm-9">@Model.Party.PartyName</dd>

                <dt class="col-sm-3">Phone Number</dt>
                <dd class="col-sm-9">@Model.Party.PhoneNumber</dd>

                <dt class="col-sm-3">Party Size</dt>
                <dd class="col-sm-9">@Model.Party.PartySize</dd>

                <dt class="col-sm-3">Notes</dt>
                <dd class="col-sm-9">@Model.Party.Notes</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Party.Status</dd>

                @* WAITING INFO *@
                @if (Model.Party.Status == "Waiting")
                {
                    <dt class="col-sm-3">Current Wait</dt>
                    <dd class="col-sm-9">
                        @(Model.Party.CurrentWaitMinutes.HasValue
                            ? Model.Party.CurrentWaitMinutes + " min"
                            : "—")
                    </dd>
                }

                @* SEATED INFO *@
                @if (Model.Party.Status == "Seated" && Model.CurrentTable != null)
                {
                    <dt class="col-sm-3">Seated At</dt>
                    <dd class="col-sm-9">
                        Table @Model.CurrentTable.TableNumber
                        <br />
                        <a asp-page="/RestaurantTables/Details"
                               asp-route-id="@Model.CurrentTable.TableId"
                               class="btn btn-sm btn-outline-secondary mt-2">
                            View Table
                        </a>
                    </dd>
                }

            </dl>

            <div class="mt-4 d-flex gap-3 fade-in-4">

                @* Manager: can edit any party *@
                @if (User.IsInRole("Manager"))
                {
                    <a class="btn-primary btn-sm" asp-page="Edit" asp-route-id="@Model.Party.PartyId">Edit</a>
                }
                else
                {
                    @* Guest: can edit only their own Waiting party *@
                    if (Model.Party.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier)
                        && Model.Party.Status == "Waiting")
                    {
                        <a class="btn-primary btn-sm" asp-page="Edit" asp-route-id="@Model.Party.PartyId">Edit</a>
                    }
                }

                <a class="btn-secondary" asp-page="Index">Back to List</a>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
