@page "{id:int}"
@model HOST.Pages.Parties.DeleteModel

@{
    ViewData["Title"] = "Delete Party";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-3 fade-in-2">@ViewData["Title"]</h1>

    @if (Model.Party.Status != "Waiting")
    {
        <div class="alert alert-danger fade-in-3">
            <strong>This party cannot be deleted.</strong><br />
            Only parties that are still <strong>Waiting</strong> in the queue may be deleted.
        </div>

        <p class="mt-3 text-pink-dark">
            <strong>Current Status:</strong> @Model.Party.Status
        </p>

        <a asp-page="Index" class="btn-secondary mt-3">Back</a>
    }
    else
    {
        <h4 class="text-pink-dark fade-in-2">Are you sure you want to delete this party?</h4>

        <div class="card card-pink shadow mt-4 fade-in-3">
            <div class="card-body p-4">

                <dl class="row text-pink-dark">
                    <dt class="col-sm-3">Party Name</dt>
                    <dd class="col-sm-9">@Model.Party.PartyName</dd>

                    <dt class="col-sm-3">Phone Number</dt>
                    <dd class="col-sm-9">@Model.Party.PhoneNumber</dd>

                    <dt class="col-sm-3">Party Size</dt>
                    <dd class="col-sm-9">@Model.Party.PartySize</dd>

                    <dt class="col-sm-3">Notes</dt>
                    <dd class="col-sm-9">@Model.Party.Notes</dd>
                </dl>

                <form method="post" class="fade-in-4 mt-4">
                    <input type="hidden" asp-for="Party.PartyId" />

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-danger-pink btn-hero">Delete</button>
                        <a class="btn-secondary" asp-page="Index">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
