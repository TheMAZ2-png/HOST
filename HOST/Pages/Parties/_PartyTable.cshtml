@model IList<HOST.Models.Party>
@using System.Security.Claims

@{
    var counter = 1;
}

<table class="table table-pink mt-3">
    <thead>
        <tr>
            <th>#</th> <!-- NEW COUNTER COLUMN -->

            <th>Party Name</th>

            @if (User.IsInRole("Manager") || User.IsInRole("Server") || User.IsInRole("Host"))
            {
                <th>Phone Number</th>
            }

            <th>Party Size</th>

            @if (User.IsInRole("Manager") || User.IsInRole("Server") || User.IsInRole("Host"))
            {
                <th>Notes</th>
            }

            <th>Wait Time</th>

            <th class="text-end"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@counter</td> <!-- COUNTER VALUE -->
                @{
                    counter++;
                }

                <td>@item.PartyName</td>

                @if (User.IsInRole("Manager") || User.IsInRole("Server") || User.IsInRole("Host"))
                {
                    <td>@item.PhoneNumber</td>
                }

                <td>@item.PartySize</td>

                @if (User.IsInRole("Manager") || User.IsInRole("Server") || User.IsInRole("Host"))
                {
                    <td>@item.Notes</td>
                }

                <td>
                    @(
                        item.CurrentWaitMinutes.HasValue
                            ? item.CurrentWaitMinutes + " min"
                            : "-"
                    )
                </td>

                <td class="text-end">
                    <div class="action-buttons">

                        @* DETAILS *@
                        @if (User.IsInRole("Manager") || User.IsInRole("Server") || User.IsInRole("Host"))
                        {
                            <a class="btn-secondary btn-sm" asp-page="Details" asp-route-id="@item.PartyId">Details</a>
                        }
                        else if (item.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                        {
                            <a class="btn-secondary btn-sm" asp-page="Details" asp-route-id="@item.PartyId">Details</a>
                        }

                        @* EDIT *@
                        @if (User.IsInRole("Manager"))
                        {
                            <a class="btn-primary btn-sm" asp-page="Edit" asp-route-id="@item.PartyId">Edit</a>
                        }
                        else if (item.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                        {
                            <a class="btn-primary btn-sm" asp-page="Edit" asp-route-id="@item.PartyId">Edit</a>
                        }

                        @* DELETE *@
                        @if (User.IsInRole("Manager"))
                        {
                            <a class="btn-danger-pink btn-sm" asp-page="Delete" asp-route-id="@item.PartyId">Delete</a>
                        }
                        else if (item.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                        {
                            <form method="post"
                                  asp-page="Edit"
                                  asp-page-handler="Delete"
                                  asp-route-id="@item.PartyId"
                                  class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete your party?');">
                                <button type="submit" class="btn-danger-pink btn-sm">Delete</button>
                            </form>
                        }

                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
