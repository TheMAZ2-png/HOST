@page
@model HOST.Pages.Parties._PartyTableModel
@using System.Security.Claims

@{
    var counter = 1;
    bool isManager = User.IsInRole("Manager");
    bool isHost = User.IsInRole("Host");
    bool isServer = User.IsInRole("Server");
    bool isStaff = isManager || isHost || isServer;

    string userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<table class="table table-pink mt-3">
    <thead>
        <tr>
            <th>#</th>
            <th>Party Name</th>

            @if (isStaff)
            {
                <th>Phone Number</th>
            }

            <th>Party Size</th>

            @if (isStaff)
            {
                <th>Notes</th>
            }

            <th>Wait Time</th>
            <th>Est. Wait</th>

            <th class="text-end"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Parties)
        {
            <tr>
                <td>@counter</td>
                @{
                    counter++;
                }

                <td>@item.PartyName</td>

                @if (isStaff)
                {
                    <td>@item.PhoneNumber</td>
                }

                <td>@item.PartySize</td>

                @if (isStaff)
                {
                    <td>@item.Notes</td>
                }

                <!-- WAIT TIME -->
                <td>
                    @if (item.Status == "Waiting" || item.Status == "Seated")
                    {
                        @(item.ActualWaitMinutes.HasValue
                            ? $"{item.ActualWaitMinutes} min"
                            : "0 min")
                    }
                    else if (item.Status == "Completed" && item.ActualWaitMinutes.HasValue)
                    {
                        @($"{item.ActualWaitMinutes} min")
                    }
                    else
                    {
                        <text>—</text>
                    }
                </td>

                <!-- ESTIMATED WAIT -->
                <td>
                    @if (item.Status == "Waiting")
                    {
                        @(item.EstimatedWaitMinutes <= 5
                            ? "Seating soon"
                            : $"{item.EstimatedWaitMinutes} min")
                    }
                    else if ((item.Status == "Seated" || item.Status == "Completed")
                             && item.EstimatedWaitAtJoin.HasValue)
                    {
                        @($"{item.EstimatedWaitAtJoin} min")
                    }
                    else
                    {
                        <text>—</text>
                    }
                </td>

                <!-- ACTIONS -->
                <td class="text-end">
                    <div class="action-buttons">

                        <!-- DETAILS -->
                        @if (isStaff || item.OwnerId == userId)
                        {
                            <a class="btn-secondary btn-sm"
                                   asp-page="Details"
                                   asp-route-id="@item.PartyId">
                                Details
                            </a>
                        }

                        <!-- EDIT -->
                        @if (isManager || (item.Status == "Waiting" && item.OwnerId == userId))
                        {
                            <a class="btn-primary btn-sm"
                                   asp-page="Edit"
                                   asp-route-id="@item.PartyId">
                                Edit
                            </a>
                        }

                        <!-- DELETE -->
                        @if (isManager)
                        {
                            <a class="btn-danger-pink btn-sm"
                                   asp-page="Delete"
                                   asp-route-id="@item.PartyId">
                                Delete
                            </a>
                        }
                        else if (item.Status == "Waiting" && item.OwnerId == userId)
                        {
                            <form method="post"
                                  asp-page="Edit"
                                  asp-page-handler="Delete"
                                  asp-route-id="@item.PartyId"
                                  class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete your party?');">
                                <button type="submit" class="btn-danger-pink btn-sm">Delete</button>
                            </form>
                        }

                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
