@page
<meta http-equiv="refresh" content="60">
@using System.Security.Claims
@model HOST.Pages.Parties.IndexModel

@{
    ViewData["Title"] = "Parties";
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    @* Manager-only controls *@
    @if (User.IsInRole("Manager"))
    {
        <div class="mb-3 fade-in-3">
            <a class="btn-primary btn-hero" asp-page="Create">New Party</a>
        </div>

        <div class="mb-4 fade-in-3">
            <form method="post" asp-page-handler="DeleteAll" class="d-inline">
                <button type="submit"
                        class="btn-danger-pink btn-hero"
                        onclick="return confirm('Are you sure you want to delete ALL parties?');">
                    Delete All Parties
                </button>
            </form>
        </div>
    }

    @* ============================
       STAFF VIEW (Manager/Host/Server)
       ============================ *@
    @if (User.IsInRole("Manager") || User.IsInRole("Host") || User.IsInRole("Server"))
    {
        <!-- WAITING PARTIES -->
        <h3 class="mt-4">Waiting Parties</h3>
        <partial name="_PartyTable" model="Model.WaitingParties" />

        <!-- SEATED PARTIES -->
        <h3 class="mt-5">Seated Parties</h3>
        <partial name="_PartyTable" model="Model.SeatedParties" />

        <!-- COMPLETED PARTIES -->
        <h3 class="mt-5">Completed Parties</h3>
        <partial name="_PartyTable" model="Model.CompletedParties" />
    }
    else
    {
        @* ============================
           GUEST VIEW (only their own Waiting party)
           ============================ *@
        <h3>Your Party</h3>
        <partial name="_PartyTable" model="Model.WaitingParties" />
    }

</div>
