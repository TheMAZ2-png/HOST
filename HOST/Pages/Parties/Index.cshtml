@page
@using System.Security.Claims
@model HOST.Pages.Parties.IndexModel

@{
    ViewData["Title"] = "Parties";

    bool isManager = User.IsInRole("Manager");
    bool isHost = User.IsInRole("Host");
    bool isServer = User.IsInRole("Server");
    bool isStaff = isManager || isHost || isServer;
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <!-- Manager-only controls -->
    @if (isManager)
    {
        <div class="mb-3 fade-in-3">
            <a class="btn-primary btn-hero" asp-page="Create">New Party</a>
        </div>

        <div class="mb-4 fade-in-3">
            <form method="post" asp-page-handler="DeleteAll" class="d-inline">
                <button type="submit"
                        class="btn-danger-pink btn-hero"
                        onclick="return confirm('Are you sure you want to delete ALL parties? They will be moved to the Deleted Parties section.');">
                    Delete All Parties
                </button>
            </form>
        </div>
    }

    <!-- STAFF VIEW -->
    @if (isStaff)
    {
        <h3 class="mt-4">Waiting Parties</h3>
        <partial name="_PartyTable_Full" model="Model.WaitingParties" />

        <h3 class="mt-5">Seated Parties</h3>
        <partial name="_PartyTable_Full" model="Model.SeatedParties" />

        <h3 class="mt-5">Completed Parties</h3>
        <partial name="_PartyTable_Full" model="Model.CompletedParties" />
    }
    else
    {
        <!-- GUEST VIEW -->
        <h3 class="mt-4">Waiting Parties</h3>
        <partial name="_PartyTable_Full" model="Model.WaitingParties" />

        <h3 class="mt-5">Completed Parties</h3>
        <partial name="_PartyTable_Full" model="Model.CompletedParties" />
    }

    <!-- ⭐ MANAGER-ONLY: Deleted Parties -->
    @if (isManager)
    {
        <h3 class="mt-5 text-pink-dark">Deleted Parties</h3>

        <div class="card card-pink shadow fade-in-4 mt-3">
            <div class="card-body p-4">

                @if (Model.DeletedParties.Any())
                {
                    <table class="table table-pink">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Size</th>
                                <th>Deleted At</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var party in Model.DeletedParties)
                            {
                                <tr>
                                    <td>@party.PartyName</td>
                                    <td>@party.PhoneNumber</td>
                                    <td>@party.PartySize</td>
                                    <td>@party.DeletedAt?.ToString("yyyy-MM-dd HH:mm")</td>

                                    <td class="text-end">
                                        <form method="post" asp-page-handler="Restore" asp-route-id="@party.PartyId">
                                            <button class="btn-primary btn-sm">Restore</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No deleted parties.</p>
                }

            </div>
        </div>
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
