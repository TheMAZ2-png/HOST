@page
@model HOST.Pages.CurriculumPages.ChatbotModel
@{
    ViewData["Title"] = "Chat, With Chat";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>AI Chat Assistant</title>

    <style>
            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                background: #ffe6f2; /* Soft pink */
                margin: 0;
                padding: 20px;
            }

            .chat-container {
                width: 80%;
                max-width: 900px;
                margin: auto;
            }

            h2 {
                text-align: center;
                color: #cc0066;
                font-weight: 700;
                margin-bottom: 20px;
            }

            .chat-box {
                background: white;
                border-radius: 15px;
                padding: 20px;
                height: 500px;
                overflow-y: auto;
                border: 2px solid #ffb3d9;
                box-shadow: 0 4px 12px rgba(255, 105, 180, 0.2);
            }

            .bubble {
                max-width: 70%;
                padding: 12px 16px;
                margin: 10px 0;
                border-radius: 18px;
                line-height: 1.4;
                font-size: 15px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            }

            .user {
                background: linear-gradient(135deg, #ff66b3, #ff3385);
                color: white;
                margin-left: auto;
                text-align: right;
            }

            .ai {
                background: #ffe6f2;
                color: #660033;
                margin-right: auto;
                border: 1px solid #ffb3d9;
            }

            .input-area {
                margin-top: 20px;
                display: flex;
                gap: 10px;
            }

            textarea {
                width: 100%;
                height: 70px;
                padding: 12px;
                border-radius: 12px;
                border: 2px solid #ff99cc;
                resize: none;
                font-size: 15px;
                outline: none;
                transition: 0.2s;
            }

                textarea:focus {
                    border-color: #ff4da6;
                    box-shadow: 0 0 6px rgba(255, 77, 166, 0.4);
                }

            button {
                padding: 12px 24px;
                background: linear-gradient(135deg, #ff4da6, #ff1a8c);
                color: white;
                border: none;
                border-radius: 12px;
                cursor: pointer;
                font-size: 16px;
                font-weight: 600;
                transition: 0.2s;
            }

                button:hover {
                    background: linear-gradient(135deg, #ff1a8c, #e60073);
                    transform: translateY(-2px);
                }
    </style>
</head>

<body>
    <div class="chat-container">
        <h2>AI Chat Assistant</h2>

        <div id="chatHistory" class="chat-box">
            @foreach (var msg in Model.ChatHistory)
            {
                <div class="bubble @(msg.Role)">
                    @msg.Text
                </div>
            }
        </div>

        <form method="post">
            <div class="input-area">
                <textarea name="UserQuestion" placeholder="Ask something..." required></textarea>
                <button type="submit">Send</button>
            </div>
        </form>
    </div>

    <script>
            // Auto-scroll to bottom
            var chatBox = document.getElementById("chatHistory");
            chatBox.scrollTop = chatBox.scrollHeight;
    </script>
</body>
</html>
