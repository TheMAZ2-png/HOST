@page
@model HOST.Pages.CurriculumPages.ChatbotModel
@{
    ViewData["Title"] = "AI Assistant";
}

<h1>AI Assistant – Menu Item Allergy Checker</h1>

<form method="post">
    <div>
        <label for="SelectedItemId">Select a Menu Item</label>
        <select asp-for="SelectedItemId"
                asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Items, "item_id", "name"))">
            <option value="">-- choose an item --</option>
        </select>
    </div>

    <div style="margin-top: 15px;">
        <label for="UserQuestion">Ask a question about allergies or ingredients</label><br />
        <textarea asp-for="UserQuestion" rows="4" cols="80"></textarea>
    </div>

    <div style="margin-top: 15px;">
        <button type="submit" disabled="@(Model.IsProcessing ? "disabled" : null)">Ask</button>
    </div>

    <div asp-validation-summary="All"></div>
</form>

@if (!string.IsNullOrEmpty(Model.AIResponse))
{
    <h2>AI Response</h2>
    <pre>@Model.AIResponse</pre>
}
