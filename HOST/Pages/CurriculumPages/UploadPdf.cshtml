@page
@model HOST.Pages.CurriculumPages.UploadPdfModel
@{
    ViewData["Title"] = "Upload PDF to Menu Data";
}

<h1>Upload PDF &amp; Digest to Menu JSON</h1>
<p>Upload a PDF document, provide a menu name, and let AI convert it into structured JSON saved to MongoDB.</p>

<hr />

<!-- Step 1: Upload PDF -->
<h3>Step 1: Upload PDF</h3>
<form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="CurriculumName" class="form-label"><strong>Menu Name</strong></label>
        <input type="text" class="form-control" asp-for="CurriculumName" placeholder="e.g. Mario Specials Menu" />
    </div>
    <div class="mb-3">
        <label for="PdfFile" class="form-label">Select a PDF file</label>
        <input type="file" class="form-control" asp-for="PdfFile" accept=".pdf" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@(Model.IsProcessing ? "disabled" : null)">
        Upload &amp; Digest
    </button>
</form>

<div asp-validation-summary="All" class="text-danger mt-3"></div>

@if (!string.IsNullOrEmpty(Model.ExtractedText))
{
    <hr />
    <h3>Extracted Text</h3>
    <div class="card mb-3">
        <div class="card-body" style="max-height:300px; overflow-y:auto;">
            <pre style="white-space:pre-wrap;">@Model.ExtractedText</pre>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.AiJsonResult))
{
    <hr />
    <h3>Step 2: Review AI‑Digested Menu JSON</h3>
    <p>Menu Name: <strong>@Model.CurriculumName</strong></p>
    <div class="card mb-3">
        <div class="card-body" style="max-height:400px; overflow-y:auto;">
            <pre style="white-space:pre-wrap;">@Model.AiJsonResult</pre>
        </div>
    </div>

    <!-- Step 2: Save to MongoDB -->
    <form method="post" asp-page-handler="Save">
        <button type="submit" class="btn btn-success">Save to MongoDB</button>
    </form>
}

@if (!string.IsNullOrEmpty(Model.SavedMessage))
{
    <hr />
    <div class="alert alert-success">@Model.SavedMessage</div>
}
