@page "{id:int}"
@model HOST.Pages.QueueEntries.DeleteModel

@{
    ViewData["Title"] = "Delete Queue Entry";
}

<h1>@ViewData["Title"]</h1>

<h4>Are you sure you want to delete this queue entry?</h4>

<dl class="row">
    <dt class="col-sm-3">Party ID</dt>
    <dd class="col-sm-9">@Model.QueueEntry.PartyId</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.QueueEntry.Status</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="QueueEntry.QueueEntryId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>
