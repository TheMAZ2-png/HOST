@page
@model HOST.Pages.QueueEntries.IndexModel
@using System.Security.Claims

@{
    ViewData["Title"] = "Queue Entries";

    bool isManager = User.IsInRole("Manager");
    bool isHost = User.IsInRole("Host");
    bool isServer = User.IsInRole("Server");
    bool isStaff = isManager || isHost || isServer;

    int counter = 1;
}

<div class="container mt-5 fade-in-1">

    <h1 class="text-pink-dark mb-4 fade-in-2">@ViewData["Title"]</h1>

    <div class="card card-pink shadow fade-in-4">
        <div class="card-body p-4">

            @if (!isStaff)
            {
                <div class="alert alert-info">
                    Queue information is only available to restaurant staff.
                </div>
            }
            else
            {
                <table class="table-pink fade-in-4">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Party Name</th>
                            <th>Party Size</th>
                           
                            <th>Created At</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.QueueEntries)
                        {
                            <tr>
                                <td>@counter</td>
                                @{
                                    counter++;
                                }

                                <td>@item.Party?.PartyName</td>
                                <td>@item.Party?.PartySize</td>
                                
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                                <td class="text-end">
                                    <div class="action-buttons">

                                        <a class="btn-secondary btn-sm"
                                               asp-page="Details"
                                               asp-route-id="@item.QueueEntryId">
                                            Details
                                        </a>

                                        <a class="btn-primary btn-sm"
                                               asp-page="Edit"
                                               asp-route-id="@item.QueueEntryId">
                                            Edit
                                        </a>

                                        <a class="btn-danger-pink btn-sm"
                                               asp-page="Delete"
                                               asp-route-id="@item.QueueEntryId">
                                            Delete
                                        </a>

                                        <a class="btn-primary btn-sm"
                                               asp-page="Seat"
                                               asp-route-id="@item.QueueEntryId">
                                            Seat
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>

</div>
