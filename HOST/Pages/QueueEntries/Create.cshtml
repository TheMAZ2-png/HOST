@page
@model HOST.Pages.QueueEntries.CreateModel

@{
    ViewData["Title"] = "Create Queue Entry";
}

<h1>@ViewData["Title"]</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="QueueEntry.PartyId" class="form-label"></label>
        <input asp-for="QueueEntry.PartyId" class="form-control" type="number" />
        <span asp-validation-for="QueueEntry.PartyId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QueueEntry.Notes" class="form-label"></label>
        <textarea asp-for="QueueEntry.Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="QueueEntry.Notes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QueueEntry.PublicAccessCode" class="form-label"></label>
        <input asp-for="QueueEntry.PublicAccessCode" class="form-control" />
        <span asp-validation-for="QueueEntry.PublicAccessCode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QueueEntry.Status" class="form-label"></label>
        <input asp-for="QueueEntry.Status" class="form-control" />
        <span asp-validation-for="QueueEntry.Status" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QueueEntry.EstimatedWaitMinutes" class="form-label"></label>
        <input asp-for="QueueEntry.EstimatedWaitMinutes" class="form-control" type="number" />
        <span asp-validation-for="QueueEntry.EstimatedWaitMinutes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QueueEntry.SeatedAt" class="form-label"></label>
        <input asp-for="QueueEntry.SeatedAt" class="form-control" type="datetime-local" />
        <span asp-validation-for="QueueEntry.SeatedAt" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
