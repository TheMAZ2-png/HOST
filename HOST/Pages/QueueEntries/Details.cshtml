@page "{id:int}"
@model HOST.Pages.QueueEntries.DetailsModel

@{
    ViewData["Title"] = "Queue Entry Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Party ID</dt>
    <dd class="col-sm-9">@Model.QueueEntry.PartyId</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.QueueEntry.Status</dd>

    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.QueueEntry.Notes</dd>

    <dt class="col-sm-3">Public Access Code</dt>
    <dd class="col-sm-9">@Model.QueueEntry.PublicAccessCode</dd>

    <dt class="col-sm-3">Estimated Wait</dt>
    <dd class="col-sm-9">@(Model.QueueEntry.EstimatedWaitMinutes?.ToString() ?? "-")</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.QueueEntry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Updated At</dt>
    <dd class="col-sm-9">@(Model.QueueEntry.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

    <dt class="col-sm-3">Seated At</dt>
    <dd class="col-sm-9">@(Model.QueueEntry.SeatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.QueueEntry.QueueEntryId">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
