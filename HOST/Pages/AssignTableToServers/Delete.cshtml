@page "{id:int}"
@model HOST.Pages.AssignTableToServers.DeleteModel

@{
    ViewData["Title"] = "Delete Assignment";
}

<h1>@ViewData["Title"]</h1>

<h4>Are you sure you want to delete this assignment?</h4>

<dl class="row">
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.Assignment.EmployeeID</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Assignment.Name</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Assignment.EmployeeID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>
