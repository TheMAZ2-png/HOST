@page "{id:int}"
@model HOST.Pages.AssignTableToServers.DetailsModel

@{
    ViewData["Title"] = "Assignment Details";
}

<h1>@ViewData["Title"]</h1>

<dl class="row">
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.Assignment.EmployeeID</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Assignment.Name</dd>

    <dt class="col-sm-3">Display Name</dt>
    <dd class="col-sm-9">@Model.Assignment.DisplayName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Assignment.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Assignment.Phone</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.Assignment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Updated At</dt>
    <dd class="col-sm-9">@(Model.Assignment.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
</dl>

<a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.Assignment.EmployeeID">Edit</a>
<a class="btn btn-secondary" asp-page="Index">Back to List</a>
