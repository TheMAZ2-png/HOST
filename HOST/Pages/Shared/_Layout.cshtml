<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>@ViewData["Title"] - HOST</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HOST.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

    @if (ViewData["HideNavbar"] == null)
    {
        <header>
            <nav class="navBar">
                <ul>

                    <!-- HOME ICON (all authenticated roles) -->
                    @if (User.IsInRole("Manager") || User.IsInRole("Host") || User.IsInRole("Server"))
                    {
                        <li>
                            <a asp-page="/homePage" class="icon-button">
                                <img src="~/Imgs/Icons/home.svg" alt="Home" />
                            </a>
                        </li>
                    }

                    <!-- BOOK ICON (authenticated users) -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <a asp-page="/CurriculumPages/Index" class="icon-button">
                                <img src="~/Imgs/Icons/Specials.svg" alt="Specials" />
                            </a>
                        </li>

                        <!-- PLAY ICON -->
                        <li>
                            <a asp-page="CurriculumPages/Chatbot" class="icon-button">
                                <img src="~/Imgs/Icons/AIPage.svg" alt="Chat with Chat" />
                            </a>
                        </li>
                        <li>
                            <a asp-page="CurriculumPages/UploadPdf">Upload PDF</a>
                        </li>

                    }


                    @if (User.IsInRole("Guest"))
                    {
                        <li>
                            <a asp-page="/Parties/Index">
                                Parties
                            </a>
                        </li>
                    }


                    <!-- ============================
                         MANAGER NAVIGATION
                         ============================ -->
                    @if (User.IsInRole("Manager"))
                    {
                        <!-- SEATING DROPDOWN -->
                        <li class="has-dropdown">
                            <a href="#">Seating</a>
                            <ul class="dropdown">
                                <li><a asp-page="/QueueEntries/Index">Queue</a></li>
                                <li><a asp-page="/RestaurantTables/Index">Tables</a></li>
                                <li><a asp-page="/Parties/Index">Parties</a></li>
                            </ul>
                        </li>

                        <!-- EMPLOYEES DROPDOWN -->
                        <li class="has-dropdown">
                            <a href="#">Employees</a>
                            <ul class="dropdown">
                                <li><a asp-page="/Employees/Index">Employees</a></li>
                                <li><a asp-page="/ManagerAccounts/Index">Managers</a></li>
                            </ul>
                        </li>

                        <!-- MANAGEMENT DROPDOWN -->
                        <li class="has-dropdown">
                            <a href="#">Management</a>
                            <ul class="dropdown">
                                <li><a asp-page="/errorLog">Logs</a></li>
                                <li><a asp-page="/AdminInsight/Insight">Insight</a></li>
                            </ul>
                        </li>
                    }

                    <!-- ============================
                         HOST / SERVER NAVIGATION
                         ============================ -->
                    @if (User.IsInRole("Host") || User.IsInRole("Server"))
                    {
                        <li class="has-dropdown">
                            <a href="#">Seating</a>
                            <ul class="dropdown">
                                <li><a asp-page="/QueueEntries/Index">Queue</a></li>
                                <li><a asp-page="/RestaurantTables/Index">Tables</a></li>
                                <li><a asp-page="/Parties/Index">Parties</a></li>
                            </ul>
                        </li>
                    }

                    <!-- ============================
                         GUEST NAVIGATION (unchanged)
                         ============================ -->
                    @if (!(User.IsInRole("Manager") || User.IsInRole("Host") || User.IsInRole("Server")))
                    {
                        <!-- Your guest nav stays unchanged -->
                    }

                    <!-- ============================
                         USER NAME + LOGOUT
                         ============================ -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <span>@User.FindFirst("PartyName")?.Value</span>
                        </li>

                        <li>
                            <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="logout-form">
                                <button type="submit" class="icon-button">
                                    <img src="~/Imgs/Icons/log-out.svg" alt="Logout" />
                                </button>
                            </form>
                        </li>
                    }

                </ul>
            </nav>
        </header>
    }

    <div class="container-fluid">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted py-4 mt-5">
        <div class="container text-center">
            &copy; 2025 - HOST System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
