<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>@ViewData["Title"] - HOST</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HOST.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

    @if (ViewData["HideNavbar"] == null)
    {
        <header>
            <nav class="navBar">
                <ul>

                   @if (User.IsInRole("Manager") || User.IsInRole("Host") || User.IsInRole("Server"))
                    {
                        <li>
                            <a asp-page="/homePage" class="icon-button">
                                <img src="~/Imgs/Icons/home.svg" alt="Home" />
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Manager") || User.IsInRole("Host") || User.IsInRole("Server"))
                    {
                    
                        <li>
                            <a asp-page="/RestaurantTables/Index">Tables</a>
                        </li>

                        <li>
                            <a asp-page="/Seatings/Index">Seating</a>
                        </li>
                    }
                    <!-- Parties -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <a asp-page="/Parties/Index">Parties</a>
                        </li>

                        @if (User.IsInRole("Manager"))
                        {
                            <li>
                                <a asp-page="/Employees/Index">Employees</a>
                            </li>
                            <li>
                                <a asp-page="/ManagerAccounts/Index">Manager Accounts</a>
                            </li>
                            <li>
                                <a asp-page="/QueueEntries/Index">Queue Entries</a>
                            </li>
                        }

                        @if (User.IsInRole("Manager"))
                        {
                            <li>
                                <a asp-page="/errorLog">Error Logging</a>
                            </li>
                        }
                    }



                    <!-- Username -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <span>@User.FindFirst("PartyName")?.Value</span>
                        </li>

                        <!-- Logout -->
                        <li>
                            <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="logout-form">
                                <button type="submit" class="icon-button">
                                    <img src="~/Imgs/Icons/log-out.svg" alt="Logout" />
                                </button>
                            </form>
                        </li>
                    }

                </ul>
            </nav>
        </header>
    }

    <div class="container-fluid">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted py-4 mt-5">
        <div class="container text-center">
            &copy; 2025 - HOST System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
