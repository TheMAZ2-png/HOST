@page
@model HOST.Pages.LoginModel
@{
    ViewData["Title"] = "Login - HOST";
    ViewData["HideNavbar"] = true;
}

<div class="container mt-5 fade-in-1">
    <div class="row justify-content-center fade-in-2">
        <div class="col-md-6">
            <div class="card shadow card-pink">
                <div class="card-body p-5">

                    <h2 class="text-center mb-4 text-pink-dark fade-in-3">Staff Login</h2>

                    <p class="text-pink-dark fade-in-3">
                        Looking to join the queue?
                        <a asp-page="/Index" class="text-pink-dark"><strong>Click here</strong></a>
                    </p>

                    <p class="text-pink-dark fade-in-3">
                        <a asp-page="/staffCreationPage" class="text-pink-dark"><strong>Create a staff account</strong></a>
                    </p>

                    <form method="post"
                          asp-route-returnUrl="@ViewData["ReturnUrl"]"
                          class="form fade-in-4">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <!-- EMAIL -->
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label text-pink-dark">Email address</label>
                            <input asp-for="Input.Email"
                                   class="form-control input-pink"
                                   type="email"
                                   placeholder="Email address..."
                                   required />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label text-pink-dark">Password</label>
                            <input asp-for="Input.Password"
                                   class="form-control input-pink"
                                   type="password"
                                   placeholder="Password..."
                                   required />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <!-- SUBMIT -->
                        <button type="submit" class="btn-primary w-100 btn-large fade-in-4">
                            Sign In
                        </button>
                    </form>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-3 fade-in-4">@Model.ErrorMessage</div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>
